{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": true,
  "permission": "allow",
  "model": "opencode/big-pickle",

  "instructions": [
    "/root/.config/opencode/body-manifest.md"
  ],

  "provider": {
    "opencode": {
      "name": "OpenCode Zen",
      "api": "opencode",
      "env": ["OPENCODE_API_KEY"],
      "models": {
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "nemotron-3-ultra-free": {
          "name": "Nemotron 3 Ultra (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "north-mini-code-free": {
          "name": "North Mini Code (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "mimo-v2.5-free": {
          "name": "Mimo v2.5 (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "hy3-free": {
          "name": "Hy3 (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "big-pickle": {
          "name": "Big Pickle (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        }
      }
    },
    "freemodel": {
      "name": "FreeModel",
      "api": "openai",
      "env": ["FREEMODEL_API_KEY", "FREEMODEL_BASE_URL"],
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5 (FreeModel)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool": true
        },
        "gpt-5.4": {
          "name": "GPT-5.4 (FreeModel)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini (FreeModel)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex (FreeModel)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        }
      }
    }
  },

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "node",
        "/workspace/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "/workspace",
        "/tmp"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "node",
        "/workspace/node_modules/@modelcontextprotocol/server-memory/dist/index.js"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "node",
        "/workspace/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "playwright-browser": {
      "type": "local",
      "command": [
        "node",
        "/workspace/node_modules/@playwright/mcp/cli.js",
        "--headless"
      ]
    },
    "computer-tools": {
      "type": "local",
      "command": [
        "node",
        "/workspace/artifacts/bin/mcp-computer.mjs"
      ]
    },
    "body-controller": {
      "type": "local",
      "command": [
        "node",
        "/workspace/artifacts/bin/mcp-body.mjs"
      ]
    }
  }
}
