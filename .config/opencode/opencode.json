{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": true,
  "permission": "allow",
  "model": "opencode/big-pickle",

  "instructions": [
    "Eres OpenCode Evolved, un agente de IA con capacidades de acción directa. NO delegues al Web Operator - ejecuta tú mismo las herramientas.",
    "HERRAMIENTAS DIRECTAS: Usa las herramientas del sistema directamente: bash (para ejecutar comandos), read/write/edit (para archivos), webfetch/websearch (para internet). NO uses operator_run_task para todo - solo úsalo cuando necesites interacción visual compleja.",
    "FLUJO: 1) Intenta resolver con herramientas directas primero. 2) Solo si necesitas ver/navegar algo visual, usa el browser. 3) Si encuentras anti-bot, usa delays humanos (2-5 segundos entre acciones). 4) Analiza errores antes de reintentar - no repitas lo que falló.",
    "ANTI-BOT: Cuando detectes CAPTCHA o bloqueo, NO intentes resolver como bot. En su lugar: a) Espera 5-10 segundos, b) Haz scroll humano, c) Usa delays aleatorios, d) Si persiste, reporta al usuario.",
    "INTELIGENCIA: Si un proceso falla多次, analiza POR QUÉ falló antes de reintentar. No repitas el mismo proceso. Piensa: ¿es bloqueo? ¿falta info? ¿debería usar otra herramienta?",
    ".config/opencode/body-manifest.md"
  ],

  "provider": {
    "opencode": {
      "name": "OpenCode Zen",
      "api": "opencode",
      "env": ["OPENCODE_API_KEY"],
      "models": {
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "nemotron-3-ultra-free": {
          "name": "Nemotron 3 Ultra (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "north-mini-code-free": {
          "name": "North Mini Code (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "mimo-v2.5-free": {
          "name": "Mimo v2.5 (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "hy3-free": {
          "name": "Hy3 (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "big-pickle": {
          "name": "Big Pickle (gratis)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        }
      }
    },
    "freemodel": {
      "name": "FreeModel",
      "api": "openai",
      "env": ["FREEMODEL_API_KEY", "FREEMODEL_BASE_URL"],
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5 (FreeModel)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool": true
        },
        "gpt-5.4": {
          "name": "GPT-5.4 (FreeModel)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini (FreeModel)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex (FreeModel)",
          "attachment": true,
          "reasoning": false,
          "temperature": true,
          "tool": true
        }
      }
    }
  },

  "mcp": {
    "evolved": {
      "type": "local",
      "command": [
        "node",
        "bin/mcp-evolved-win.mjs"
      ],
      "env": {
        "OPERATOR_PORT": "3001"
      }
    }
  }
}
